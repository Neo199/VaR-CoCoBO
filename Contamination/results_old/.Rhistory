PRBOCS <- function(inputs, theta_ini, order) {
# BOCS: Function runs binary optimization using simulated annealing on
# the model drawn from the distribution over beta parameters
#
# Inputs: inputs (list) specifying the parameters:
#   - x_vals, y_vals: initial samples
#   - model: target objective function f(x)
#   - penalty: regularization term P(x)
#   - order (int): statistical model order
#   - acquisitionFn:
# Extract inputs
n_vars <- inputs$n_vars
# cat("n_vars", n_vars, "\n")
model <- inputs$model
#cat("model", model, "\n")
order <- 2
x_vals <- inputs$x_vals
# cat("x_vals", x_vals, "\n")
y_vals <- inputs$y_vals
# cat("y_vals", y_vals, "\n")
# Train initial statistical model
LR <- trainLinReg(x_vals, y_vals, order, n_iter = 1)#, tau = 1, sigma2 = 1)
# Find number of iterations based on total budget
n_init <- nrow(inputs$x_vals)
n_iter <- inputs$evalBudget - n_init
# cat("n_iter", n_iter, "\n")
# browser()
# Declare vector to store results
model_iter <- matrix(0, n_iter, n_vars)
obj_iter <- numeric(n_iter)
alpha_samples <- list()
alpha_mean <- list()
alpha_median <- list()
alpha_leftCI <- list()
alpha_rightCI <- list()
# cat("net model_iter", model_iter, "\n")
# cat("net obj_iter", obj_iter, "\n")
expected_val <- theta_ini
for (t in 1:n_iter) {
# Draw alpha vector
alpha_t <- LR$alpha_in
# cat("alpha vector", length(alpha_t), "\n")
cat("alpha_t", alpha_t, "\n")
# Setup statistical model objective for the acquisition function
stat_model <- function(theta){
acquisition_func(theta, alpha_t)
}
# Optimal solution for acquisition function
# max_acq <- optim(theta_ini, stat_model, method='L-BFGS-B', lower=0.0, upper=1.0, control = list(fnscale= -1))
# print("max")
# print(max_acq)
min_acq <- optim(theta_ini, stat_model, method='L-BFGS-B', lower=0.00000001, upper=0.999999999)
# print("min")
# print(min_acq)
# expected_val <- max_acq$par
expected_val <- min_acq$par
cat("expected_val", expected_val, "\n")
x_new <- rbinom(length(expected_val), 1, expected_val)
# Evaluate model objective at the new evaluation point
x_new <- matrix(x_new, nrow=1, ncol=n_vars)
cat("New evaluation point", x_new, "\n")
#Updated model so input is transpose to it
y_new <- model(t(x_new), cost_mat, supply_mat, demand_mat)
# Update inputs list
inputs$x_vals <- rbind(inputs$x_vals, x_new)
inputs$y_vals <- c(inputs$y_vals, y_new)
inputs$init_cond <- x_new
alpha_samples[[t]] <- LR$hs_samples
alpha_mean[[t]] <- LR$alpha
alpha_median[[t]] <-LR$hs_median
alpha_leftCI[[t]] <-LR$hs_leftCI
alpha_rightCI[[t]] <-LR$hs_rightCI
tau <- LR$tau
Sigma2 <- LR$sigma2
# print("Updated X_vals")
# print(inputs$x_vals)
# Re-train linear model
# browser()
LR <- trainLinReg(inputs$x_vals, inputs$y_vals, order, n_iter = t, tau, sigma2 = Sigma2)
# Save results for optimal model
model_iter[t,] <- x_new
obj_iter[t] <- y_new # + penalty(x_new)
cat("iteration number", t, "\n")
# cat("model_iter (x_new)", model_iter, "\n")
# cat("obj_iter(y_new+penalty)", obj_iter, "\n")
}
return(list(model_iter = model_iter, obj_iter = obj_iter, iteration_num = t,
alpha_median = alpha_median, alpha = alpha_mean,
alpha_rightCI = alpha_rightCI , alpha_leftCI = alpha_leftCI,
alpha_samples = alpha_samples))
}
# Function to train the linear regression model using Gibbs sampling
trainLinReg <- function(x_vals, y_vals, order, n_iter, tau, sigma2) {
# Set nGibbs (Gibbs iterations to run)
nGibbs <- 1e3
browser()
# setup data for training
xTrain <- x_vals
yTrain <- y_vals
# print(data)
# print("xTrain")
# print(xTrain)
# cat("yTrain", yTrain, "\n")
# Generate interaction terms for the input data
xTrain_in <- order_effects(xTrain, order)
# cat("xTrain with interaction terms","\n")
# print(xTrain_in)
cDims <- dim(xTrain_in)
nSamps <- cDims[1]
nCoeffs <- cDims[2]
# cat("nSamps, nCoeffs", c(nSamps, nCoeffs), "\n")
# run Gibbs sampler for nGibbs steps
# browser()
# gibbsResult <- runGibbs(xTrain_in, yTrain, nGibbs)
# if(class(gibbsResult=="try-error")){
#   TEMP = list(xTrain_in, yTrain)
# }
n <- nrow(xTrain_in)
p <- ncol(xTrain_in)
# Normalize data
result_std <- standardise(xTrain_in, yTrain)
X <- result_std$X
y <- result_std$y
muY <- result_std$muY
# Return values
alpha <- matrix(0, nrow = p, ncol = nGibbs)
s2 <- matrix(0, nrow = 1, ncol = nGibbs)
t2 <- matrix(0, nrow = 1, ncol = nGibbs)
l2 <- matrix(0, nrow = p, ncol = nGibbs)
if(n_iter == 1){
horseshoe_results <- horseshoe(y, X, method.tau = "truncatedCauchy",
method.sigma = "Jeffreys",
burn = nGibbs/3, nmc = 1000, thin = 1, alpha = 0.05)
}
else{
horseshoe_results <- horseshoe_new(y, X, method.tau = "truncatedCauchy", tau = tau,
method.sigma = "Jeffreys", Sigma2 = sigma2,
burn = nGibbs/3, nmc = 1000, thin = 1, alpha = 0.05)
}
#Quantifying uncertainty
hs_median <- horseshoe_results$BetaMedian
hs_leftCI <- horseshoe_results$LeftCI
hs_rightCI <- horseshoe_results$RightCI
hs_samples <- horseshoe_results$BetaSamples
pSigma <- horseshoe_results$Sigma2Hat
pTau <- horseshoe_results$TauHat
# print(horseshoe_results)
a0 <- muY
alpha <- horseshoe_results$BetaHat
s2 <- horseshoe_results$Sigma2Samples
t2<- horseshoe_results$TauSamples
# cat("alpha gibbs shape", dim(alpha), "\n")
# cat("alpha gibbs", alphaGibbs, "\n")
gibbsResult <- list(alpha = alpha, a0 = a0)
alphaGibbs <- gibbsResult$alpha
a0 <- gibbsResult$a0
alpha_in <- c(a0, alphaGibbs)
hs_results <- list(alpha_in = alpha_in , alpha= alpha, hs_median =hs_median,
hs_leftCI= hs_leftCI,hs_rightCI= hs_rightCI, hs_samples= hs_samples,
sigma2=pSigma, tau =pTau)
# cat("alpha length", length(alpha), "\n")
# cat("alpha", alpha, "\n")
# cat("a0", a0, "\n")
return(hs_results)
}
# Function to generate interaction terms up to a given order
order_effects <- function(xTrain, order) {
# Find dimensions of the matrix
n_samp <- nrow(xTrain)
n_vars <- ncol(xTrain)
# Initialize result matrix
xTrain_in <- xTrain
# Generate interaction terms for each order up to ord_t
for (ord_i in 2:order) {
# Generate all combinations of indices (without diagonals)
cat("ord_i", ord_i, "\n")
cat("n_vars", n_vars, "\n")
offdProd <- combn(n_vars, ord_i)
# Generate products of input variables
x_comb <- array(dim = c(n_samp, ncol(offdProd)))
for (j in 1:ncol(offdProd)) {
x_comb[, j] <- apply(xTrain[, offdProd[, j]], 1, prod)
}
# Append interaction terms to the result matrix
xTrain_in <- cbind(xTrain_in, x_comb)
}
return(xTrain_in)
}
# Function for standardizing data
standardise <- function(X, y) {
n <- nrow(X)
meanX <- colMeans(X)
stdX <- apply(X, 2, sd) * sqrt(n)
X <- scale(X, center = meanX, scale = FALSE)
muY <- mean(y)
y <- scale(y)
stdlist <- list(X = X, muY = muY, y = y)
return(stdlist)
}
acquisition_func <- function(theta, alpha) {
# AQUISITION FUNCTION: Function evaluates the linear model
# reparameterized acquisition
# Assumption: input theta only contains one row
# Generate outer product of theta
outer <- tcrossprod(theta)
# Extract the upper triangular elements
upp_out <- upper_tri_masking(outer)
# cat("thetaij", upp_out, "\n")
# Extract the diagonal elements
diag_out <- diag(outer)
# cat("theta_j", diag_out, "\n")
# browser()
# Generate pr_all which forms the input vector for the surrogate
coeffs <- c(diag_out, upp_out)
pr_all <- c(1, coeffs)
# print(nrow(pr_all))
# Compute and return objective with barrier
out <- sum(pr_all * alpha)
return(out)
}
