library(lpSolve)
library(ompr)
set.seed(1)
# Set inputs
n_vars <-3
evalBudget <-50
n_init <- 3
lambda <- .2
weights_ini <- rep(0.5, n_vars)
# Define cost matrix
# cost_mat <- matrix(c(7, 84, 40, 2, 91, 0, 0, 0,25), nrow = n_vars, ncol = n_vars)
# cost_mat <- matrix(runif(n_vars^2, min = 5, max = 100), nrow = n_vars, ncol = n_vars)
cost_mat <- c(20, 50, 30)
wire_mat <- matrix(c(0, 15, 30, 15, 0, 15, 30, 15, 0), nrow = n_vars, ncol = n_vars)
#Defining the random supply and demand matrices for now
# supply_mat <- runif(n_vars, min = 5, max = 1000)
# demand_mat <- runif(n_vars, min = 5, max = 1000)
supply_mat <- c(100, 20, 50)
demand_mat <- c(80,30,40)
# Define the model
model <- function(x_matrix, cost_mat, supply_mat, demand_mat) {
# wire_cost <- wire_mat #give input of adjacency matrix here
# wire_cost <- t(wire_cost)[lower.tri(t(wire_cost))]
penalty <- rowSums(supply_mat * x_matrix) - rowSums(demand_mat * x_matrix)
# cost <- sum(cost_mat * x_matrix) +  sum(wire_cost) -lambda*penalty
cost <- rowSums(cost_mat * x_matrix) -lambda*penalty
return(cost)
}
