# Run PRBOCS
prbocs_inputs <- list(
n_vars = n_vars,
x_vals = x_vals,
y_vals = y_vals,
model = model,
evalBudget = evalBudget,
n_init = n_init,
lambda = lambda,
supply_mat = supply_mat,
demand_mat = demand_mat,
wire_cost = wire_mat
)
prbocs_inputs
